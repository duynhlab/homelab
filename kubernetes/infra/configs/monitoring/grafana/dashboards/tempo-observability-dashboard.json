        {
          "datasource": {
            "type": "tempo",
            "uid": "${DS_TEMPO}"
          },
          "limit": 20,
          "query": "{resource.service.name=~\"$service\" && name=~\"$operation\"}",
          "queryType": "traceqlSearch",
          "refId": "A",
          "tableType": "traces"
        }
      ],
      "title": "TraceQL Search",
      "type": "traces"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "description": "Top 10 slowest spans by P99 latency",
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "cellOptions": {
              "type": "auto"
            },
            "inspect": false
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.5
              },
              {
                "color": "red",
                "value": 1
              }
            ]
          },
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 1
      },
      "id": 2,
      "options": {
        "cellHeight": "sm",
        "footer": {
          "countRows": false,
          "fields": "",
          "reducer": ["sum"],
          "show": false
        },
        "showHeader": true
      },
      "pluginVersion": "11.0.0",
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "editorMode": "code",
          "expr": "topk(10, histogram_quantile(0.99, sum by(span_name, service_name, le) (rate(traces_spanmetrics_latency_bucket{service_name=~\"$service\"}[$__rate_interval]))))",
          "format": "table",
          "instant": true,
          "legendFormat": "__auto",
          "range": false,
          "refId": "A"
        }
      ],
      "title": "Top 10 Slow Spans (P99)",
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "le": true
            },
            "includeByName": {},
            "indexByName": {
              "Time": 0,
              "Value": 3,
              "service_name": 1,
              "span_name": 2
            },
            "renameByName": {
              "Value": "P99 Latency",
              "service_name": "Service",
              "span_name": "Operation"
            }
          }
        }
      ],
      "type": "table"
    },
