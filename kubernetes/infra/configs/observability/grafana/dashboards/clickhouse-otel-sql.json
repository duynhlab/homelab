    {
      "id": 19,
      "type": "table",
      "title": "Cross-signal: traces \u2194 correlated logs",
      "description": "The RFC-0019 payoff: otel_traces ANY LEFT JOIN otel_logs ON TraceId \u2014 traces vs correlated log lines per service, in one store.",
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "${ds}"
      },
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 12,
        "y": 46
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "${ds}"
          },
          "editorType": "sql",
          "rawSql": "SELECT t.ServiceName AS service, count(DISTINCT t.TraceId) AS traces, count(l.TraceId) AS correlated_logs FROM otel.otel_traces t ANY LEFT JOIN otel.otel_logs l ON t.TraceId = l.TraceId WHERE $__timeFilter(t.Timestamp) AND t.TraceId != '' AND t.ServiceName IN (${service:singlequote}) GROUP BY t.ServiceName ORDER BY traces DESC",
          "format": 1,
          "queryType": "table",
          "pluginVersion": "4.19.0"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "filterable": true,
            "cellOptions": {
              "type": "auto"
            },
            "inspect": true
          }
        },
        "overrides": []
      },
      "options": {
        "showHeader": true,
        "cellHeight": "sm",
        "footer": {
          "show": false
        }
      }
    },
