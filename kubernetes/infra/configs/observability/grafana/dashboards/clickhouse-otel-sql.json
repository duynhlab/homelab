            "type": "grafana-clickhouse-datasource",
            "uid": "${ds}"
          },
          "editorType": "sql",
          "rawSql": "SELECT $__timeInterval(Timestamp) AS time, 100.0*countIf(StatusCode='STATUS_CODE_ERROR')/greatest(count(),1) AS v FROM otel.otel_traces WHERE $__timeFilter(Timestamp) AND ServiceName IN (${service:singlequote}) GROUP BY time ORDER BY time",
          "format": 1,
          "queryType": "timeseries",
          "pluginVersion": "4.19.0"
        }
