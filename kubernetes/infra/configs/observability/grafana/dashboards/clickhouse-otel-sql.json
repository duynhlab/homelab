          "editorType": "sql",
          "rawSql": "SELECT ServiceName, SpanName, count() AS calls, round(quantile(0.95)(Duration)/1e6,2) AS p95_ms, round(quantile(0.99)(Duration)/1e6,2) AS p99_ms FROM otel.otel_traces WHERE $__timeFilter(Timestamp) AND ServiceName IN (${service:singlequote}) GROUP BY ServiceName, SpanName ORDER BY p95_ms DESC LIMIT 15",
