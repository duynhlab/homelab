    {
      "id": 11,
      "type": "table",
      "title": "Slowest traces",
      "description": "Ranked by wall-clock trace duration (last span end minus first span start), so traces with long async tails rank correctly.",
      "gridPos": {
        "x": 0,
        "y": 30,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "${ds}"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "${ds}"
          },
          "editorType": "sql",
          "rawSql": "SELECT r.Timestamp AS Time, r.ServiceName AS Root, r.SpanName AS Operation, agg.Spans AS Spans, round(r.Duration/1e6, 2) AS root_ms, agg.TraceMs AS trace_ms, if(agg.ErrSpans > 0, 'Error', 'Ok') AS Status, r.TraceId AS TraceId FROM otel.otel_traces AS r INNER JOIN (SELECT TraceId, count() AS Spans, countIf(StatusCode = 'Error') AS ErrSpans, anyIf(StatusMessage, StatusCode = 'Error') AS ErrMsg, round((max(toUnixTimestamp64Nano(Timestamp) + toInt64(Duration)) - min(toUnixTimestamp64Nano(Timestamp)))/1e6, 2) AS TraceMs FROM otel.otel_traces WHERE $__timeFilter(Timestamp) GROUP BY TraceId) AS agg ON r.TraceId = agg.TraceId WHERE $__timeFilter(r.Timestamp) AND r.ParentSpanId = '' AND r.TraceId IN (SELECT DISTINCT TraceId FROM otel.otel_traces WHERE $__timeFilter(Timestamp) AND $__conditionalAll(ResourceAttributes['deployment.environment.name'] IN (${environment:singlequote}), $environment) AND $__conditionalAll(ServiceName IN (${service:singlequote}), $service) AND $__conditionalAll(SpanName IN (${spanname:singlequote}), $spanname) AND $__conditionalAll(TraceId = '$traceid', $traceid)) AND $__conditionalAll(if(agg.ErrSpans > 0, 'Error', 'Ok') IN (${status:singlequote}), $status) AND $__conditionalAll(r.Duration >= toUInt64($min_duration_ms) * 1000000, $min_duration_ms) ORDER BY agg.TraceMs DESC LIMIT 20",
