  },
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "Volume",
      "collapsed": false,
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 24,
        "h": 1
      },
      "panels": []
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Trace volume by status",
      "description": "One row per trace; a trace is Error if ANY of its spans failed. The Trace status filter applies to this classification.",
      "gridPos": {
        "x": 0,
        "y": 1,
        "w": 14,
        "h": 8
      },
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "${ds}"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "${ds}"
          },
          "editorType": "sql",
          "rawSql": "SELECT $__timeInterval(start) AS time, Status, count() AS traces FROM (SELECT TraceId, min(Timestamp) AS start, if(countIf(StatusCode = 'Error') > 0, 'Error', 'Ok') AS Status FROM otel.otel_traces WHERE $__timeFilter(Timestamp) AND TraceId IN (SELECT DISTINCT TraceId FROM otel.otel_traces WHERE $__timeFilter(Timestamp) AND $__conditionalAll(ResourceAttributes['deployment.environment.name'] IN (${environment:singlequote}), $environment) AND $__conditionalAll(ServiceName IN (${service:singlequote}), $service) AND $__conditionalAll(SpanName IN (${spanname:singlequote}), $spanname)) GROUP BY TraceId HAVING $__conditionalAll(Status IN (${status:singlequote}), $status)) GROUP BY time, Status ORDER BY time",
          "format": 0,
          "queryType": "timeseries",
          "pluginVersion": "4.20.0"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 1,
            "fillOpacity": 18,
            "showPoints": "auto",
            "pointSize": 5,
            "axisSoftMin": 0,
            "stacking": {
              "mode": "normal",
              "group": "A"
            }
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byRegexp",
              "options": ".*Error.*"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "red"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byRegexp",
              "options": ".*Ok.*"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "green"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byRegexp",
              "options": ".*Unset.*"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "text"
                }
              }
            ]
          }
        ]
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "mean",
            "max",
            "last"
          ],
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Traces",
      "description": "Traces in the current service/span selection. Ignores the Trace status and Trace ID filters.",
      "gridPos": {
        "x": 14,
        "y": 1,
        "w": 3,
        "h": 8
      },
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "${ds}"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "${ds}"
          },
          "editorType": "sql",
          "rawSql": "SELECT count() AS traces FROM (SELECT TraceId, min(Timestamp) AS start, if(countIf(StatusCode = 'Error') > 0, 'Error', 'Ok') AS Status FROM otel.otel_traces WHERE $__timeFilter(Timestamp) AND TraceId IN (SELECT DISTINCT TraceId FROM otel.otel_traces WHERE $__timeFilter(Timestamp) AND $__conditionalAll(ResourceAttributes['deployment.environment.name'] IN (${environment:singlequote}), $environment) AND $__conditionalAll(ServiceName IN (${service:singlequote}), $service) AND $__conditionalAll(SpanName IN (${spanname:singlequote}), $spanname)) GROUP BY TraceId)",
          "format": 1,
          "queryType": "table",
          "pluginVersion": "4.20.0"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "blue",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "textMode": "value_and_name",
        "wideLayout": true
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Failed traces",
      "description": "Share of traces containing at least one Error span. Ignores the Trace status and Trace ID filters — this stat IS the status summary.",
      "gridPos": {
        "x": 17,
        "y": 1,
        "w": 3,
        "h": 8
      },
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "${ds}"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "${ds}"
          },
          "editorType": "sql",
          "rawSql": "SELECT 100.0*countIf(Status = 'Error')/count() AS err_pct FROM (SELECT TraceId, min(Timestamp) AS start, if(countIf(StatusCode = 'Error') > 0, 'Error', 'Ok') AS Status FROM otel.otel_traces WHERE $__timeFilter(Timestamp) AND TraceId IN (SELECT DISTINCT TraceId FROM otel.otel_traces WHERE $__timeFilter(Timestamp) AND $__conditionalAll(ResourceAttributes['deployment.environment.name'] IN (${environment:singlequote}), $environment) AND $__conditionalAll(ServiceName IN (${service:singlequote}), $service) AND $__conditionalAll(SpanName IN (${spanname:singlequote}), $spanname)) GROUP BY TraceId)",
          "format": 1,
          "queryType": "table",
          "pluginVersion": "4.20.0"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 1
              },
              {
                "color": "red",
                "value": 5
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "textMode": "value_and_name",
        "wideLayout": true
      }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "p99 (server spans)",
      "description": "",
      "gridPos": {
        "x": 20,
        "y": 1,
        "w": 4,
        "h": 8
      },
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "${ds}"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "${ds}"
          },
          "editorType": "sql",
          "rawSql": "SELECT round(quantile(0.99)(Duration)/1e6, 1) AS p99_ms FROM otel.otel_traces WHERE $__timeFilter(Timestamp) AND $__conditionalAll(ResourceAttributes['deployment.environment.name'] IN (${environment:singlequote}), $environment) AND $__conditionalAll(ServiceName IN (${service:singlequote}), $service) AND $__conditionalAll(SpanName IN (${spanname:singlequote}), $spanname) AND SpanKind = 'Server'",
          "format": 1,
          "queryType": "table",
          "pluginVersion": "4.20.0"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "decimals": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 200
              },
              {
                "color": "red",
                "value": 1000
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "textMode": "value_and_name",
        "wideLayout": true
      }
    },
    {
      "id": 6,
      "type": "row",
      "title": "Duration distribution",
      "collapsed": false,
      "gridPos": {
        "x": 0,
        "y": 9,
        "w": 24,
        "h": 1
      },
      "panels": []
    },
    {
      "id": 7,
      "type": "heatmap",
      "title": "Span duration distribution",
      "description": "Log2 y-scale. $sample_mod controls sampling (1 = keep every span); raise it (e.g. 500) if this panel gets heavy at high volume.",
      "gridPos": {
        "x": 0,
        "y": 10,
        "w": 24,
        "h": 9
      },
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "${ds}"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "${ds}"
          },
          "editorType": "sql",
          "rawSql": "SELECT toStartOfInterval(Timestamp, INTERVAL $__interval_s second) AS time, Duration/1000000 AS duration_ms FROM otel.otel_traces WHERE $__timeFilter(Timestamp) AND $__conditionalAll(ResourceAttributes['deployment.environment.name'] IN (${environment:singlequote}), $environment) AND $__conditionalAll(ServiceName IN (${service:singlequote}), $service) AND $__conditionalAll(SpanName IN (${spanname:singlequote}), $spanname) AND cityHash64(SpanId) % $sample_mod = 0 ORDER BY time",
          "format": 0,
          "queryType": "timeseries",
          "pluginVersion": "4.20.0"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "scaleDistribution": {
              "type": "log",
              "log": 2
            }
          }
        },
        "overrides": []
      },
      "options": {
        "calculate": true,
        "calculation": {
          "xBuckets": {
            "mode": "size"
          },
          "yBuckets": {
            "mode": "size"
          }
        },
        "yAxis": {
          "unit": "ms",
          "axisPlacement": "left"
        },
        "color": {
          "mode": "scheme",
          "scheme": "Oranges",
          "steps": 64,
          "exponent": 0.5,
          "fill": "dark-orange",
          "reverse": false
        },
        "cellGap": 1,
        "tooltip": {
          "mode": "single",
          "showColorScale": false
        },
        "legend": {
          "show": true
        },
        "exemplars": {
          "color": "rgba(255,0,255,0.7)"
        },
        "filterValues": {
          "le": 1e-09
        },
        "rowsFrame": {
          "layout": "auto"
        },
        "showValue": "never"
      }
    },
    {
      "id": 8,
      "type": "row",
      "title": "Find traces — click a TraceId to load the timeline below",
      "collapsed": false,
      "gridPos": {
        "x": 0,
        "y": 19,
        "w": 24,
        "h": 1
      },
      "panels": []
    },
    {
      "id": 9,
      "type": "table",
      "title": "Trace search",
      "description": "One row per trace (root span + rollup). Filters apply to ANY span in the trace; min duration applies to the root.",
      "gridPos": {
        "x": 0,
        "y": 20,
        "w": 24,
        "h": 9
      },
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "${ds}"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "${ds}"
          },
          "editorType": "sql",
          "rawSql": "SELECT r.Timestamp AS Time, r.ServiceName AS Root, r.SpanName AS Operation, agg.Spans AS Spans, round(r.Duration/1e6, 2) AS root_ms, agg.TraceMs AS trace_ms, if(agg.ErrSpans > 0, 'Error', 'Ok') AS Status, r.TraceId AS TraceId FROM otel.otel_traces AS r INNER JOIN (SELECT TraceId, count() AS Spans, countIf(StatusCode = 'Error') AS ErrSpans, anyIf(StatusMessage, StatusCode = 'Error') AS ErrMsg, round((max(toUnixTimestamp64Nano(Timestamp) + toInt64(Duration)) - min(toUnixTimestamp64Nano(Timestamp)))/1e6, 2) AS TraceMs FROM otel.otel_traces WHERE $__timeFilter(Timestamp) GROUP BY TraceId) AS agg ON r.TraceId = agg.TraceId WHERE $__timeFilter(r.Timestamp) AND r.ParentSpanId = '' AND r.TraceId IN (SELECT DISTINCT TraceId FROM otel.otel_traces WHERE $__timeFilter(Timestamp) AND $__conditionalAll(ResourceAttributes['deployment.environment.name'] IN (${environment:singlequote}), $environment) AND $__conditionalAll(ServiceName IN (${service:singlequote}), $service) AND $__conditionalAll(SpanName IN (${spanname:singlequote}), $spanname) AND $__conditionalAll(TraceId = '$traceid', $traceid)) AND $__conditionalAll(if(agg.ErrSpans > 0, 'Error', 'Ok') IN (${status:singlequote}), $status) AND $__conditionalAll(r.Duration >= toUInt64($min_duration_ms) * 1000000, $min_duration_ms) ORDER BY Time DESC LIMIT 50",
          "format": 1,
          "queryType": "table",
          "pluginVersion": "4.20.0"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "filterable": true,
            "cellOptions": {
              "type": "auto"
            },
            "inspect": true
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "TraceId"
            },
            "properties": [
              {
                "id": "links",
                "value": [
                  {
                    "title": "Load trace timeline",
                    "url": "/d/clickhouse-traces-explorer?var-traceid=${__value.raw}&${__url_time_range}",
                    "targetBlank": false
                  }
                ]
              },
              {
                "id": "custom.width",
                "value": 260
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Status"
            },
            "properties": [
              {
                "id": "mappings",
                "value": [
                  {
                    "type": "value",
                    "options": {
                      "Error": {
                        "color": "red",
                        "index": 0
                      },
                      "Ok": {
                        "color": "green",
                        "index": 1
                      }
                    }
                  }
                ]
              },
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "color-text"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "root_ms"
            },
            "properties": [
              {
                "id": "unit",
                "value": "ms"
              },
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "color-background",
                  "mode": "gradient"
                }
              },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    {
                      "color": "green",
                      "value": null
                    },
                    {
                      "color": "yellow",
                      "value": 100
                    },
                    {
                      "color": "red",
                      "value": 500
                    }
                  ]
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "trace_ms"
            },
            "properties": [
              {
                "id": "unit",
                "value": "ms"
              },
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "color-background",
                  "mode": "gradient"
                }
              },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    {
                      "color": "green",
                      "value": null
                    },
                    {
                      "color": "yellow",
                      "value": 100
                    },
                    {
                      "color": "red",
                      "value": 500
                    }
                  ]
                }
              }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "cellHeight": "sm",
        "footer": {
          "show": false,
          "reducer": [
            "sum"
          ],
          "countRows": false,
          "fields": ""
        }
      }
    },
    {
      "id": 10,
      "type": "row",
      "title": "Slowest & failing",
      "collapsed": false,
      "gridPos": {
        "x": 0,
        "y": 29,
        "w": 24,
        "h": 1
      },
