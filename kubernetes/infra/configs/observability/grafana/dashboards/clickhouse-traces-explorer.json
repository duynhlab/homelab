{
  "uid": "clickhouse-traces-explorer",
  "title": "OTel — Trace Explorer",
  "description": "Request investigation over ClickHouse otel_traces: where did the request go and which span broke? Search traces, inspect the waterfall, and read its correlated logs in one place.",
  "tags": [
    "clickhouse",
    "observability",
    "otel",
    "suite",
    "traces"
  ],
  "editable": true,
  "graphTooltip": 1,
  "liveNow": false,
  "schemaVersion": 38,
  "version": 1,
  "style": "dark",
  "time": {
    "from": "now-3h",
    "to": "now"
  },
  "timezone": "browser",
  "timepicker": {},
  "refresh": "30s",
  "links": [
    {
      "asDropdown": true,
      "icon": "external link",
      "includeVars": false,
      "keepTime": true,
      "tags": [
        "clickhouse"
      ],
      "targetBlank": false,
      "title": "ClickHouse suite",
      "type": "dashboards",
      "url": ""
    }
  ],
  "annotations": {
    "list": []
  },
  "templating": {
    "list": [
      {
        "name": "ds",
        "type": "datasource",
        "label": "Data source",
        "query": "grafana-clickhouse-datasource",
        "current": {
          "text": "ClickHouse",
          "value": "clickhouse"
        },
        "hide": 0,
        "includeAll": false,
        "multi": false,
        "refresh": 1,
        "regex": ""
      },
      {
        "name": "environment",
        "type": "query",
        "label": "Environment",
        "datasource": {
          "type": "grafana-clickhouse-datasource",
          "uid": "${ds}"
        },
        "definition": "SELECT DISTINCT ResourceAttributes['deployment.environment.name'] AS env FROM otel.otel_traces WHERE env != '' ORDER BY env",
        "query": {
          "refId": "A",
          "rawSql": "SELECT DISTINCT ResourceAttributes['deployment.environment.name'] AS env FROM otel.otel_traces WHERE env != '' ORDER BY env",
          "format": 1,
          "queryType": "table"
        },
        "current": {
          "text": [
            "All"
          ],
          "value": [
            "$__all"
          ]
        },
        "hide": 0,
        "includeAll": true,
        "multi": true,
        "refresh": 2,
        "sort": 0
      },
      {
        "name": "service",
        "type": "query",
        "label": "Service",
        "datasource": {
          "type": "grafana-clickhouse-datasource",
          "uid": "${ds}"
        },
        "definition": "SELECT DISTINCT ServiceName FROM otel.otel_traces ORDER BY ServiceName",
        "query": {
          "refId": "A",
          "rawSql": "SELECT DISTINCT ServiceName FROM otel.otel_traces ORDER BY ServiceName",
          "format": 1,
          "queryType": "table"
        },
        "current": {
          "text": [
            "All"
          ],
          "value": [
            "$__all"
          ]
        },
        "hide": 0,
        "includeAll": true,
        "multi": true,
        "refresh": 2,
        "sort": 0
      },
      {
        "name": "spanname",
        "type": "query",
        "label": "Span name",
        "datasource": {
          "type": "grafana-clickhouse-datasource",
          "uid": "${ds}"
        },
        "definition": "SELECT DISTINCT SpanName FROM otel.otel_traces WHERE $__conditionalAll(ServiceName IN (${service:singlequote}), $service) ORDER BY SpanName",
        "query": {
          "refId": "A",
          "rawSql": "SELECT DISTINCT SpanName FROM otel.otel_traces WHERE $__conditionalAll(ServiceName IN (${service:singlequote}), $service) ORDER BY SpanName",
          "format": 1,
          "queryType": "table"
        },
        "current": {
          "text": [
            "All"
          ],
          "value": [
            "$__all"
          ]
        },
        "hide": 0,
        "includeAll": true,
        "multi": true,
        "refresh": 2,
        "sort": 0
      },
      {
        "name": "status",
        "type": "custom",
        "label": "Trace status",
        "query": "Ok,Error",
        "options": [],
        "current": {
          "text": [
            "All"
          ],
          "value": [
            "$__all"
          ]
        },
        "hide": 0,
        "includeAll": true,
        "multi": true,
        "refresh": 0
      },
      {
        "name": "traceid",
        "type": "textbox",
        "label": "Trace ID",
        "query": "",
        "current": {
          "text": "",
          "value": ""
        },
        "options": [
          {
            "selected": true,
            "text": "",
            "value": ""
          }
        ],
        "hide": 0
      },
      {
        "name": "min_duration_ms",
        "type": "textbox",
        "label": "Min duration (ms)",
        "query": "",
