          "legendFormat": "{{rpc_method}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Product gRPC error ratio by method",
      "description": "non-OK / all responses. Business rejections (FailedPrecondition on insufficient stock) count as non-OK here \u2014 read alongside the outcomes panel.",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 10
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
