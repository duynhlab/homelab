      "description": "otelgrpc server histogram, product.v1.ProductService/*. BatchGetCurrentPrices joins after P2-1.",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 10
