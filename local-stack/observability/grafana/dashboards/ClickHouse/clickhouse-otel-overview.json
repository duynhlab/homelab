              "options": "ServiceName"
            },
            "properties": [
              {
                "id": "links",
                "value": [
                  {
                    "title": "Open in Logs Explorer",
                    "url": "/d/clickhouse-logs-explorer?var-service=${__value.raw}&${__url_time_range}",
                    "targetBlank": false
