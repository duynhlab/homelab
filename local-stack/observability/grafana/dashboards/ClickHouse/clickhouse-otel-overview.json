          "rawSql": "SELECT r.Timestamp AS Timestamp, r.ServiceName AS Root, r.SpanName AS Operation, round(r.Duration/1e6, 2) AS ms, r.TraceId AS TraceId FROM otel.otel_traces AS r INNER JOIN (SELECT TraceId FROM otel.otel_traces WHERE $__timeFilter(Timestamp) AND $__conditionalAll(ResourceAttributes['deployment.environment.name'] IN (${environment:singlequote}), $environment) GROUP BY TraceId HAVING countIf(StatusCode = 'Error') > 0) AS bad ON r.TraceId = bad.TraceId WHERE $__timeFilter(r.Timestamp) AND r.ParentSpanId = '' ORDER BY Timestamp DESC LIMIT 15",
