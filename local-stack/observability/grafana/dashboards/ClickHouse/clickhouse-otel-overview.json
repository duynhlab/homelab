    {
      "id": 13,
      "type": "row",
      "title": "Latest failures — jump into Logs or Traces",
      "collapsed": false,
      "gridPos": {
        "x": 0,
        "y": 23,
        "w": 24,
        "h": 1
      },
      "panels": []
    },
    {
      "id": 14,
      "type": "table",
      "title": "Latest error logs",
      "description": "",
      "gridPos": {
        "x": 0,
        "y": 24,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "${ds}"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "${ds}"
          },
          "editorType": "sql",
          "rawSql": "SELECT Timestamp, ServiceName, lower(SeverityText) AS SeverityText, Body, TraceId FROM otel.otel_logs WHERE $__timeFilter(Timestamp) AND $__conditionalAll(`__otel_materialized_deployment.environment.name` IN (${environment:singlequote}), $environment) AND SeverityNumber >= 17 ORDER BY Timestamp DESC LIMIT 15",
          "format": 1,
          "queryType": "table",
          "pluginVersion": "4.20.0"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "filterable": true,
            "cellOptions": {
              "type": "auto"
            },
            "inspect": true
          }
        },
        "overrides": [
          {
